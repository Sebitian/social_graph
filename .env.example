# Copy to .env.local and fill in. All keys are optional for local dev —
# without them the app serves deterministic DEMO data so you can still build/share.

# Apify — enables real Instagram scraping
APIFY_TOKEN=

# Scrape budget UI and server-side hard caps
NEXT_PUBLIC_FREE_POST_LIMIT=10
NEXT_PUBLIC_FREE_COMMENTS_PER_POST=10
NEXT_PUBLIC_MAX_POST_LIMIT=50
NEXT_PUBLIC_MAX_COMMENTS_PER_POST=100
NEXT_PUBLIC_FREE_RECIPROCITY_FRIENDS=4
NEXT_PUBLIC_FREE_RECIPROCITY_POSTS_PER_FRIEND=3
NEXT_PUBLIC_MAX_RECIPROCITY_FRIENDS=12
NEXT_PUBLIC_MAX_RECIPROCITY_POSTS_PER_FRIEND=8
NEXT_PUBLIC_FREE_PROFILE_LOOKUPS=2

# Cost estimator. The comments actor charges per returned Comment event.
NEXT_PUBLIC_APIFY_COMMENT_EVENT_COST_USD=0.0026

# Vercel KV (Redis) — caches live scrape results. Optional; in-memory fallback locally.
KV_REST_API_URL=
KV_REST_API_TOKEN=
CACHE_TTL_SECONDS=86400

# Vercel Blob — pinned snapshots for /graph/<handle>/pinned (private; not in public git)
BLOB_READ_WRITE_TOKEN=

# Public site URL (used for OG metadata / share links)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Pin a scrape to /graph/<handle>/pinned (no Apify). Optional in dev; required in production.
SNAPSHOT_PIN_SECRET=
